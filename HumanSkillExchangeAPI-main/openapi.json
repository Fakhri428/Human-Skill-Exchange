{
  "openapi": "3.0.3",
  "info": {
    "title": "Human Skill Exchange API",
    "description": "Dokumentasi REST API platform pertukaran skill, waktu, pengalaman, mentoring, bantuan project, dan kolaborasi berbasis matching dan reputasi.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost/HumanSkillExchangeAPI-main/api",
      "description": "Local XAMPP atau Laragon Server"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Register, login, logout, dan user login"
    },
    {
      "name": "Subscription",
      "description": "Paket Gratis, Pro, dan Pro Max"
    },
    {
      "name": "Profile",
      "description": "Profil personal branding pengguna"
    },
    {
      "name": "Skills",
      "description": "Skill yang dimiliki pengguna"
    },
    {
      "name": "Needs",
      "description": "Kebutuhan bantuan pengguna"
    },
    {
      "name": "Offers",
      "description": "Penawaran kontribusi pengguna"
    },
    {
      "name": "Matching",
      "description": "Rule-based matching"
    },
    {
      "name": "Exchange",
      "description": "Exchange request, status, completion, dan progress"
    },
    {
      "name": "Reviews",
      "description": "Review, rating, dan reputasi"
    }
  ],
  "paths": {
    "/register.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register user baru",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "name": "Dina",
                "email": "dina@example.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Register berhasil"
          },
          "409": {
            "description": "Email sudah digunakan"
          },
          "422": {
            "description": "Validasi gagal"
          }
        }
      }
    },
    "/login.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login dan mendapatkan Bearer Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "fakhri@example.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login berhasil",
            "content": {
              "application/json": {
                "example": {
                  "status": true,
                  "message": "Login berhasil",
                  "data": {
                    "user": {
                      "id": 1,
                      "name": "Fakhri",
                      "email": "fakhri@example.com",
                      "role": "user",
                      "plan": "Gratis"
                    },
                    "token_type": "Bearer",
                    "access_token": "fakhri-token-123"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Email atau password salah"
          }
        }
      }
    },
    "/logout.php": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout user login",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logout berhasil"
          },
          "401": {
            "description": "Token tidak valid"
          }
        }
      }
    },
    "/me.php": {
      "get": {
